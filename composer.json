{
  "name": "r4ndsen/sqlite-php",
  "type": "library",
  "description": "this library will help you deal with sqlite3 databases in php",
  "keywords": [
    "SQLite",
    "SQLite3",
    "database",
    "pdo",
    "sql",
    "db",
    "query",
    "orm",
    "data",
    "persistence",
    "lightweight",
    "embedded",
    "php"
  ],
  "authors": [{ "name": "Werner Spiegel" }],
  "support": {
    "issues": "https://github.com/r4ndsen/sqlite-php/issues",
    "source": "https://github.com/r4ndsen/sqlite-php"
  },
  "license": "MIT",
  "config": {
    "allow-plugins": {
      "infection/extension-installer": true
    },
    "sort-packages": true
  },
  "require": {
    "php": "^8.2",
    "ext-mbstring": "*",
    "ext-sqlite3": "*",
    "symfony/polyfill-php83": "^1.33",
    "symfony/polyfill-php84": "^1.33",
    "symfony/polyfill-php85": "^1.33"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.94",
    "infection/infection": "^0.31",
    "php-coveralls/php-coveralls": "^2.9",
    "phpbench/phpbench": "^1.6",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.5|^12.5",
    "psalm/plugin-phpunit": "^0.19",
    "rector/rector": "^2.3",
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "r4ndsen\\": [
        "src/"
      ]
    }
  },
  "autoload-dev": {
    "psr-4": {
      "r4ndsen\\": [
        "tests/"
      ]
    }
  }
}
