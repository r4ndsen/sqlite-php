{
  "name": "r4ndsen/sqlite",
  "type": "library",
  "description": "this library will help you deal with sqlite databases",
  "license": "MIT",
  "config": {
    "allow-plugins": {
      "infection/extension-installer": true
    }
  },
  "require": {
    "php": ">=8.2",
    "ext-mbstring": "*",
    "ext-sqlite3": "*"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.75.0",
    "roave/security-advisories": "dev-latest",
    "phpunit/phpunit": "^11.5.17",
    "phpbench/phpbench": "^1.4.1",
    "infection/infection": "^0.29.14",
    "phpstan/phpstan": "^2.1.11",
    "rector/rector": "^2.0.11"
  },
  "autoload": {
    "psr-4": {
      "r4ndsen\\": [
        "src/"
      ]
    }
  },
  "autoload-dev": {
    "psr-4": {
      "r4ndsen\\": [
        "tests/"
      ]
    }
  }
}
